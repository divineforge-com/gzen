---
import BaseLayout from "../layouts/BaseLayout.astro";
import Starfield from "../components/Starfield.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Hero from "../components/Hero.astro";
import DoorGrid from "../components/DoorGrid.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout>
  <Starfield />

  <main class="wrap">
    <ThemeToggle />
    <Hero />
    <DoorGrid />
    <SiteFooter />
  </main>

  <div class="cursor-glow" aria-hidden="true"></div>
</BaseLayout>

<style>
  .wrap {
    position: relative;
    z-index: 1;
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 1.75rem) 2.5rem;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    min-height: 100dvh;
  }

  .cursor-glow {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      520px circle at var(--px, 50%) var(--py, 20%),
      var(--cursor-glow),
      transparent 55%
    );
    opacity: 0.9;
    transition: opacity 0.4s var(--ease);
  }

  @media (prefers-reduced-motion: reduce), (pointer: coarse) {
    .cursor-glow {
      display: none;
    }
  }

  :global(.door-key-flash) {
    border-color: var(--line-strong) !important;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      0 0 32px color-mix(in srgb, var(--door-tone, var(--accent)) 22%, transparent) !important;
  }
</style>
