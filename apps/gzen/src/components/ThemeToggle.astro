---
/** Cool monastery ↔ warm ignition */
---

<div class="theme-bar reveal">
  <button
    type="button"
    class="theme-toggle"
    id="theme-toggle"
    aria-label="Switch temperature: cool monastery or warm ignition"
    title="Cool monastery · warm ignition (T)"
    aria-keyshortcuts="T">
    <span class="track" aria-hidden="true">
      <span class="knob"></span>
    </span>
    <span class="labels">
      <span class="lab lab-m" data-active-for="monastery">Cool</span>
      <span class="sep" aria-hidden="true">/</span>
      <span class="lab lab-i" data-active-for="ignite">Ignite</span>
    </span>
  </button>
</div>

<style>
  .theme-bar {
    position: absolute;
    top: clamp(1rem, 3vw, 1.5rem);
    right: 0;
    z-index: 5;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    margin: 0;
    padding: 0.35rem 0.55rem 0.35rem 0.4rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--card) 88%, transparent);
    color: var(--dim);
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    backdrop-filter: blur(8px);
    transition:
      border-color 0.25s var(--ease),
      color 0.25s var(--ease),
      background 0.25s var(--ease);
  }

  .theme-toggle:hover,
  .theme-toggle:focus-visible {
    border-color: var(--line-strong);
    color: var(--muted);
    outline: none;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .track {
    position: relative;
    width: 2rem;
    height: 1.05rem;
    border-radius: 999px;
    background: var(--line);
    border: 1px solid var(--line-strong);
    flex-shrink: 0;
  }

  .knob {
    position: absolute;
    top: 50%;
    left: 2px;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--accent);
    transform: translateY(-50%);
    transition:
      left 0.3s var(--ease),
      background 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
    box-shadow: 0 0 0 0 transparent;
  }

  :global(html[data-theme="ignite"]) .knob {
    left: calc(100% - 0.7rem - 2px);
    box-shadow: 0 0 10px color-mix(in srgb, var(--accent) 55%, transparent);
  }

  .labels {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .sep {
    opacity: 0.4;
  }

  .lab {
    transition: color 0.25s var(--ease);
  }

  :global(html[data-theme="monastery"]) .lab-m,
  :global(html:not([data-theme])) .lab-m {
    color: var(--ink);
  }

  :global(html[data-theme="ignite"]) .lab-i {
    color: var(--accent);
  }
</style>
